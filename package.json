{
  "name": "tokensentry",
  "displayName": "TokenSentry",
  "description": "TokenSentry is an extension that allows to analyze the files added before or during the commit to detect that no sensitive data is uploaded.",
  "version": "1.1.0",
  "private": true,
  "publisher": "DieLibonati",
  "icon": "public/icon.png",
  "engines": {
    "vscode": "^1.99.0",
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DiegoLibonati/TokenSentry.git"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tokensentry.alive",
        "title": "TokenSentry: Alive"
      },
      {
        "command": "tokensentry.checkFiles",
        "title": "TokenSentry: Check Files"
      }
    ],
    "configuration": {
      "title": "TokenSentry",
      "properties": {
        "tokenSentry.defaultPatterns": {
          "type": "object",
          "default": {
            "GitLab Token": {
              "pattern": "glpat-[A-Za-z0-9_-]{20}",
              "flags": "g"
            },
            "GitHub Token": {
              "pattern": "ghp_[A-Za-z0-9]{36}",
              "flags": "g"
            }
          },
          "description": "Default patterns to detect tokens (do not modify directly)."
        },
        "tokenSentry.customPatterns": {
          "type": "object",
          "default": {},
          "description": "Add your own Regex patterns (e.g. 'My Token': {'pattern': 'my_token_[0-9]{32}', 'flags': 'gi'} - flags key is OPTIONAL)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "check-types": "tsc --build --verbose",
    "check-types:app": "tsc --build tsconfig.app.json --verbose",
    "check-types:test": "tsc --build tsconfig.test.json --verbose",
    "watch:app": "tsc --build tsconfig.app.json --watch",
    "watch:test": "tsc --build tsconfig.test.json --watch",
    "dev": "tsx scripts/build.ts --watch",
    "build": "tsx scripts/build.ts --production",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:all": "eslint src __tests__ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:all": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\" \"scripts/**/*.ts\"",
    "test": "jest --verbose",
    "test:watch": "jest --watchAll --verbose",
    "test:coverage": "jest --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "20.x",
    "@types/vscode": "^1.99.0",
    "esbuild": "^0.25.10",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.0.0"
  }
}
